APP_NAME=RM Inventory Platform

# Database switch: sqlite or mssql
SQL_DIALECT=sqlite
DATABASE_URL=
SQLITE_PATH=backend/rm_inventory_demo.db

# SQL Server settings (set when switching to server DB)
SQL_SERVER=YOUR_SQL_SERVER
SQL_PORT=1433
SQL_DATABASE=YOUR_DATABASE_NAME
SQL_USER=YOUR_DB_USER
SQL_PASSWORD=YOUR_DB_PASSWORD
SQL_DRIVER=ODBC Driver 17 for SQL Server

# Security
JWT_SECRET_KEY=PLEASE_CHANGE_TO_A_RANDOM_SECRET
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_HOURS=8

# Upload
UPLOAD_MAX_FILE_SIZE_MB=20

# Local sqlite demo seed (disable in production-like environment)
SEED_SQLITE_DEMO=1
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_PASSWORD=CHANGE_ME
